# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# --------------------------------------------------
# Virtual Environment
# --------------------------------------------------
venv/
.venv/
env/

# --------------------------------------------------
# Environment Variables
# --------------------------------------------------
.env

# --------------------------------------------------
# Jupyter Notebook
# --------------------------------------------------
.ipynb_checkpoints/

# --------------------------------------------------
# VS Code
# --------------------------------------------------
.vscode/

# --------------------------------------------------
# Dashboard Exports
# --------------------------------------------------
dashboard/data_exports/*

# Keep Folder Structure
!dashboard/data_exports/.gitkeep

# --------------------------------------------------
# Data Files
# --------------------------------------------------
data/raw/*
data/processed/*
data/external/*

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# --------------------------------------------------
# Outputs
# --------------------------------------------------
outputs/models/*
outputs/figures/*
outputs/metrics/*
outputs/predictions/*

# Keep folder structure
!outputs/models/.gitkeep
!outputs/figures/.gitkeep
!outputs/metrics/.gitkeep
!outputs/predictions/.gitkeep

# --------------------------------------------------
# Model Files
# --------------------------------------------------
*.pkl
*.joblib
*.h5

# --------------------------------------------------
